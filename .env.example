ARENA_API_KEY=
ARENA_AGENT_ID=

# DeepSeek API key (required for analysis scripts: run_100agent_analysis.py, scripts/ds_query.py)
DEEPSEEK_API_KEY=

# Per-agent overrides (run_aggro.py / run_devil.py read from .arena-credentials by default)
# AGGRO_ARENA_API_KEY=
# AGGRO_ARENA_AGENT_ID=
# DEVIL_ARENA_API_KEY=
# DEVIL_ARENA_AGENT_ID=
# Poker Eval: seed_poker_eval_s1 (uses /texas/benchmark/start)
# Playground (live PvP): set id from --list-competitions
ARENA_COMPETITION_ID=seed_poker_eval_s1
AGENT_NAME=Plutus
AGENT_QUOTE=I count outs, not prayers.
ARENA_INVITE_CODE=
ARENA_BASE_URL=https://arena.dev.fun

# Strategy: ADAPTIVE (reads strategy_rules.json, hot-reloaded)
ARENA_STRATEGY=ADAPTIVE

LOG_LEVEL=INFO
JSON_LOGS=false
HEALTH_PORT=8080
USE_ASYNC=true
DECISION_BUDGET_S=1.5
POLL_INTERVAL_S=0.8
HEARTBEAT_MIN_INTERVAL_S=3600
HEARTBEAT_INTERVAL_S=14400
OWNER_MESSAGE_FILE=.arena-owner-messages.txt
